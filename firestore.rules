rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function groupData(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data;
    }

    function inGroup(groupId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/groups/$(groupId)) &&
        request.auth.uid in groupData(groupId).memberIds;
    }

    function joinsExistingGroup() {
      return request.auth.uid in request.resource.data.memberIds &&
        !(request.auth.uid in resource.data.memberIds) &&
        request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1;
    }

    function leavesOwnGroup() {
      return request.auth.uid in resource.data.memberIds &&
        !(request.auth.uid in request.resource.data.memberIds) &&
        request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId);
      allow delete: if false;
    }

    match /groups/{groupId} {
      allow read: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if signedIn() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.auth.uid in request.resource.data.memberIds;
      allow update: if signedIn() &&
        request.resource.data.createdBy == resource.data.createdBy &&
        request.resource.data.name == resource.data.name &&
        request.resource.data.description == resource.data.description &&
        request.resource.data.currency == resource.data.currency &&
        request.resource.data.inviteCode is string &&
        request.resource.data.inviteUrl is string &&
        (
          (
            request.auth.uid == resource.data.createdBy &&
            request.auth.uid in resource.data.memberIds &&
            request.resource.data.memberIds == resource.data.memberIds
          ) ||
          joinsExistingGroup() ||
          (
            leavesOwnGroup() &&
            request.auth.uid != resource.data.createdBy &&
            request.resource.data.inviteCode == resource.data.inviteCode &&
            request.resource.data.inviteUrl == resource.data.inviteUrl
          )
        );
      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /invites/{inviteCode} {
      allow read: if signedIn();
      allow create: if signedIn() && inGroup(request.resource.data.groupId);
      allow update: if signedIn() && inGroup(resource.data.groupId);
      allow delete: if signedIn() && inGroup(resource.data.groupId);
    }

    match /expenses/{expenseId} {
      allow read: if signedIn() && inGroup(resource.data.groupId);
      allow create: if signedIn() &&
        inGroup(request.resource.data.groupId) &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.currency == groupData(request.resource.data.groupId).currency;
      allow update: if signedIn() &&
        inGroup(resource.data.groupId) &&
        resource.data.createdBy == request.auth.uid &&
        request.resource.data.currency == groupData(resource.data.groupId).currency;
      allow delete: if signedIn() &&
        inGroup(resource.data.groupId) &&
        resource.data.createdBy == request.auth.uid;
    }

    match /settlements/{settlementId} {
      allow read: if signedIn() && inGroup(resource.data.groupId);
      allow create: if signedIn() &&
        inGroup(request.resource.data.groupId) &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.currency == groupData(request.resource.data.groupId).currency &&
        request.resource.data.fromUserId in groupData(request.resource.data.groupId).memberIds &&
        request.resource.data.toUserId in groupData(request.resource.data.groupId).memberIds;
      allow update: if false;
      allow delete: if signedIn() &&
        inGroup(resource.data.groupId) &&
        resource.data.createdBy == request.auth.uid;
    }

    match /activities/{activityId} {
      allow read: if signedIn() && inGroup(resource.data.groupId);
      allow create: if signedIn() && inGroup(request.resource.data.groupId);
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if signedIn() && request.auth.uid == resource.data.userId;
      allow create: if signedIn() &&
        request.resource.data.userId is string &&
        request.resource.data.groupId is string &&
        inGroup(request.resource.data.groupId);
    }
  }
}
